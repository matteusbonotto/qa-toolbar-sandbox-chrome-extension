# Public client values only. Never add service-role keys to extension builds.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Backend exclusivo do pacote de extensão [TESTE]. Nunca use a URL de produção aqui.
# Sem valor, o comando usa o Supabase local em http://127.0.0.1:54321/functions/v1.
QTS_TEST_FUNCTIONS_BASE_URL=
VITE_ENTITLEMENT_PUBLIC_KEY=
WXT_PUBLIC_OFFLINE_LICENSE_PUBLIC_JWK={"kty":"RSA","n":"PUBLIC_MODULUS","e":"AQAB"}

# Configure the same public values as GitHub Actions repository variables.
# They are browser identifiers, never APP_SUPABASE_SECRET_KEY/service-role keys.
# The Pages workflow intentionally fails when either public value is absent.

# Browser-safe public configuration only
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_REF=

# Edge Function secrets — configure with `supabase secrets set`, never VITE_*
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_ENDPOINT_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_SCALE_YEARLY_PRICE_ID=
STRIPE_REGRESSION_RUNNER_MONTHLY_PRICE_ID=
STRIPE_REGRESSION_RUNNER_YEARLY_PRICE_ID=
# Optional modern aliases; the bootstrap also accepts the legacy PRO/SCALE names above.
STRIPE_ROOT_CAUSE_ANALYST_MONTHLY_PRICE_ID=
STRIPE_ROOT_CAUSE_ANALYST_YEARLY_PRICE_ID=
STRIPE_RELEASE_MANAGER_MONTHLY_PRICE_ID=
STRIPE_RELEASE_MANAGER_YEARLY_PRICE_ID=
STRIPE_REFERRAL_PROMOTION_CODE_ID=
STRIPE_30OFF_PROMOTION_CODE_ID=
APP_SUPABASE_PUBLIC_KEY=
APP_SUPABASE_SECRET_KEY=
CHECKOUT_SUCCESS_URL=
CHECKOUT_CANCEL_URL=
KEEP_ALIVE_SECRET=
OFFLINE_LICENSE_PRIVATE_JWK=
# Origins contain scheme + host (+ optional port), never a URL path.
ALLOWED_ORIGINS=https://matteusbonotto.github.io,http://127.0.0.1:4173,http://localhost:4173
# Comma-separated IDs accepted by Edge Function CORS (Chrome Web Store and local/unpacked builds).
ALLOWED_EXTENSION_IDS=ddaapjklnfjhjigeglgmjmadjnmdodfe,jaalcifngdkpenjdolhlkgcaepdpkgoe,pkmfnaknekoffbaihajgglhehhpogkoj,ninmkchkkdckompjggialfboljlabdkf,gcjepbjbgcldicfnknplggjghhpmmime,kpmdhklfhodlelggbbinggpcfdflahjd,llakhonfpcohfjmafkjpjdacehdbppcg
# Chrome Web Store listing used after access confirmation
CHROME_WEB_STORE_URL=https://chromewebstore.google.com/detail/qa-toolbar-sandbox/ddaapjklnfjhjigeglgmjmadjnmdodfe?authuser=0&hl=pt-BR

# Chrome Web Store Publish API — see docs/DEPLOY_CHROME_WEBSTORE.md for the one-time setup.
# CLIENT_ID/CLIENT_SECRET come from a Google Cloud OAuth "Desktop app" client; REFRESH_TOKEN
# comes from running `npm run chrome-webstore:oauth-setup` once. Never commit real values.
CHROME_WEBSTORE_CLIENT_ID=
CHROME_WEBSTORE_CLIENT_SECRET=
CHROME_WEBSTORE_REFRESH_TOKEN=
# Optional — defaults to the real published item ID above; only set to override.
CHROME_WEBSTORE_EXTENSION_ID=

# Private voucher values belong only in .env.private; never commit them.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Local-only input for supabase/seed-test-users.mjs. Never commit a real value.
QTS_TEST_USER_PASSWORD=
QTS_VOUCHER_MBLABS_CODE=
QTS_VOUCHER_CNKLT_CODE=
QTS_VOUCHER_ONO_CODE=
