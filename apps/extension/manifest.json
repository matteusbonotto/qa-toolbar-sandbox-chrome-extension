{
  "manifest_version": 3,
  "name": "QA Toolbar Sandbox",
  "version": "1.1.3",
  "description": "Toolbar local-first com contexto, evidências, Key View, Macro Studio, Input Lab, Faker Fill e ferramentas rápidas de QA.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "QA Toolbar Sandbox — abrir configurações",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "https://matteusbonotto.github.io/qa-toolbar-sandbox-chrome-extension/*",
      "http://localhost:5173/*"
    ]
  },
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["src/assets/sounds/*.mp3"],
      "matches": ["<all_urls>"]
    }
  ],
  "minimum_chrome_version": "116"
}
