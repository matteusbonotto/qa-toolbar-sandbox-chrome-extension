{
  "manifest_version": 3,
  "name": "QA Toolbar Sandbox",
  "version": "1.0.0",
  "description": "Barra de ferramentas de QA local-first: contexto, status de teste, evidências e inspectors sem sair da página que você está validando.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "QA Toolbar Sandbox — abrir configurações",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_page": "src/options/options.html",
  "minimum_chrome_version": "116"
}
